{
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../app",
    "beforeBuildCommand": "npm run build --prefix ../app",
    "devPath": "http://localhost:1420",
    "distDir": "../app/dist"
  },
  "package": {
    "productName": "ice",
    "version": "0.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.ice.app"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "ice",
        "width": 800,
        "height": 600
      }
    ]
  }
}